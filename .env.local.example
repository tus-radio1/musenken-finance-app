# =============================================================================
# .env.local — ローカル開発用環境変数
# =============================================================================
# このファイルをコピーして .env.local を作成してください。
#   cp .env.local.example .env.local
#
# ローカルの Supabase を起動するには:
#   supabase start
# 起動後に表示される "API URL" と "anon key", "service_role key" をコピーしてください。
# =============================================================================

# -----------------------------------------------------------------------------
# Supabase (ローカル)
# supabase start の出力から取得
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=<supabase start の "anon key">
SUPABASE_SERVICE_ROLE_KEY=<supabase start の "service_role key">

# -----------------------------------------------------------------------------
# 会計システムユーザー UUID
# ローカルDBのシードデータに含まれる UUID を設定（通常は本番と同じ値でよい）
# system_config テーブルの accounting_user_id カラムの値を参照してください。
# -----------------------------------------------------------------------------
ACCOUNTING_SYSTEM_USER_ID=9701edd2-bd9d-4d57-9dd6-7235686103bf
NEXT_PUBLIC_ACCOUNTING_SYSTEM_USER_ID=9701edd2-bd9d-4d57-9dd6-7235686103bf
