# =============================================================================
# Supabase Configuration
# =============================================================================

# Supabase project URL (public, used in both client and server)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase anonymous key (public, used for client-side auth)
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIs...

# Supabase service role key (secret, server-side only - never expose to client)
# Used for admin operations: user creation, password reset, storage uploads
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIs...

# Supabase database connection URL (for running migrations)
SUPABASE_DB_URL=postgresql://postgres:your-password@db.your-project-ref.supabase.co:5432/postgres

# =============================================================================
# Application Configuration
# =============================================================================

# Accounting system user ID (UUID of the accounting bot/system user)
# Falls back to hardcoded value if not set
ACCOUNTING_SYSTEM_USER_ID=9701edd2-bd9d-4d57-9dd6-7235686103bf

# Public accounting system user ID (used in client components)
NEXT_PUBLIC_ACCOUNTING_SYSTEM_USER_ID=9701edd2-bd9d-4d57-9dd6-7235686103bf
