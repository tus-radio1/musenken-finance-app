# =============================================================================
# .env.production — 本番環境変数（Vercel などのホスティング環境に設定）
# =============================================================================
# このファイルはテンプレートです。実際の値は Vercel ダッシュボードの
# "Environment Variables" に直接入力してください。
# ⚠️ .env.production ファイルをリポジトリにコミットしないでください。
#
# 値の取得場所:
#   Supabase Dashboard → Settings → API → Project URL / Project API keys
# =============================================================================

# -----------------------------------------------------------------------------
# Supabase (本番)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<Supabase Dashboard の "anon public" キー>
SUPABASE_SERVICE_ROLE_KEY=<Supabase Dashboard の "service_role" キー（秘密）>

# -----------------------------------------------------------------------------
# 会計システムユーザー UUID
# Supabase Dashboard → Table Editor → system_config → accounting_user_id の value
# -----------------------------------------------------------------------------
ACCOUNTING_SYSTEM_USER_ID=<system_config テーブルの accounting_user_id の value>
NEXT_PUBLIC_ACCOUNTING_SYSTEM_USER_ID=<上記と同じ値>
